{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": [
      "vite/client"
    ],
    "esModuleInterop": true,
    "declaration": true
  },
  "include": [
    "src",
    ".storybook"
  ]
}